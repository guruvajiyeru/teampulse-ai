{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n SERVER,CLIENT -c cyan,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npx tsx server.ts",
    "dev:client": "cd client && npx vite",
    "build": "cd client && npx vite build",
    "build:server": "cd server && npm run build",
    "build:all": "npm run build && npm run build:server",
    "deploy:netlify": "npm run build && npx netlify deploy --prod --dir=client/dist",
    "start": "cd server && node dist/server.cjs",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "mongoose": "^9.6.2",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.7",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.0",
    "netlify": "^26.0.2",
    "render-cli": "^0.3.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
